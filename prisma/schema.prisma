generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  name      String?
  createdAt DateTime   @default(now())
  srsItems  SRSItem[]
  reviewLogs ReviewLog[]
}

model SRSItem {
  id               String   @id @default(cuid())
  subjectMain      String   // Equivalent to Google Sheet Column A
  subjectSub       String   // Equivalent to Google Sheet Column B
  createdAt        DateTime @default(now()) // Column C
  
  tutorPromptDocId String?  // Column D - legacy, now stores item ID for URL
  tutorPromptContent String? // Full tutor prompt text, served via /tutor/[id]
  
  semester         Int      @default(1) // Tracks which semester this module belongs to
  
  currentLevel     Int      @default(0) // Column E
  nextReviewDate   DateTime // Column F
  
  quiz1DocId       String?  // Column G
  quiz2DocId       String?  // Column H
  quiz3DocId       String?  // Column I
  quiz4DocId       String?  // Column J
  quiz5DocId       String?  // Column K
  quiz6DocId       String?  // Mastery Stage 1 (Tag 180)
  quiz7DocId       String?  // Mastery Stage 2 (Tag 365)
  
  sourceMaterialId String?  // Column L
  sourceMaterialContent String?
  
  // Didactic Context (Added to give Grader context)
  blueprint        String?
  coverageLedger   String?
  
  // Grading History and Explainer Prompts (Phase 2 additions)
  lastFeedback     String?
  lastVideoPrompt1 String?
  lastVideoPrompt2 String?
  
  // NotebookLM Podcast Integration
  notebookId       String?
  prePodcastPrompt String?
  postPodcastPrompt String?
  prePodcastUrl    String?
  postPodcastUrl   String?
  videoUrl         String?
  
  // Relationship to User for future multi-tenant support
  userId           String?
  user             User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([nextReviewDate])
  @@index([subjectMain])
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

model BackgroundJob {
  id          String    @id @default(cuid())
  type        String    // "quiz_generation" or "grading"
  status      String    @default("pending") // pending, processing, done, error
  subjectMain String
  subjectSub  String    @default("Module")
  itemId      String?   // for grading jobs, references SRSItem
  error       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt
  completedAt DateTime?

  @@index([status, createdAt])
}

model AppConfig {
  id              Int      @id @default(1)
  currentSemester Int      @default(1)
  modulePresets   String   @default("[]") // JSON string array
  language        String   @default("german") // german or english
  wrapperMode     String   @default("all") // "all", "generation_only", "none"
  updatedAt       DateTime @updatedAt
}

model ReviewLog {
  id          String   @id @default(cuid())
  subjectMain String
  subjectSub  String
  level       Int      // The level they were at when they reviewed
  passed      Boolean  // Did they pass or repeat?
  completedAt DateTime @default(now())
  // Feedback history: the full Remediation Brief of THIS review, so grading
  // no longer overwrites the past (SRSItem.lastFeedback only holds the latest).
  feedback    String?
  // The SRSItem this review belongs to (soft reference — logs survive item deletion).
  itemId      String?
  userId      String?
  User        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([completedAt])
}
