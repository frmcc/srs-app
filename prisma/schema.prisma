generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  name      String?
  createdAt DateTime   @default(now())
  srsItems  SRSItem[]
  reviewLogs ReviewLog[]
}

model SRSItem {
  id               String   @id @default(cuid())
  subjectMain      String   // Equivalent to Google Sheet Column A
  subjectSub       String   // Equivalent to Google Sheet Column B
  createdAt        DateTime @default(now()) // Column C
  
  tutorPromptDocId String?  // Column D - legacy, now stores item ID for URL
  tutorPromptContent String? // Quiz-phase tutor prompt (pre-grading), served via /tutor/[id]
  // Assessment-phase tutor prompt (post-grading) — loaded once the examiner's
  // per-task assessment exists. Old items without it fall back to the quiz prompt.
  tutorPromptAssessmentContent String?
  
  semester         Int      @default(1) // Tracks which semester this module belongs to
  
  currentLevel     Int      @default(0) // Column E
  nextReviewDate   DateTime // Column F
  // Monotonic optimistic-lock counter, bumped on every grading write. Guards
  // concurrent gradings of the SAME item regardless of PASS/REPEAT (currentLevel
  // alone can't — a REPEAT doesn't change it).
  version          Int      @default(0)
  
  quiz1DocId       String?  // Column G
  quiz2DocId       String?  // Column H
  quiz3DocId       String?  // Column I
  quiz4DocId       String?  // Column J
  quiz5DocId       String?  // Column K
  quiz6DocId       String?  // Mastery Stage 1 (Tag 180)
  quiz7DocId       String?  // Mastery Stage 2 (Tag 365)
  
  sourceMaterialId String?  // Column L
  sourceMaterialContent String?
  
  // Didactic Context (Added to give Grader context)
  blueprint        String?
  coverageLedger   String?
  
  // Grading History and Explainer Prompts (Phase 2 additions)
  lastFeedback     String?
  lastVideoPrompt1 String?
  lastVideoPrompt2 String?
  
  // NotebookLM Podcast Integration
  notebookId       String?
  prePodcastPrompt String?
  postPodcastPrompt String?
  prePodcastUrl    String?
  postPodcastUrl   String?
  videoUrl         String?
  
  // Comprehension check (library "weak-spot quiz"): latest score only —
  // each run overwrites. Kept OUT of the SRS schedule and review stats.
  comprehensionScore    Float?
  comprehensionPassed   Boolean?
  comprehensionAt       DateTime?
  comprehensionFeedback String?
  comprehensionQuizText String?
  
  // Relationship to User for future multi-tenant support
  userId           String?
  user             User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([nextReviewDate])
  @@index([subjectMain])
  // Legacy tutor deep-links resolve items by this column; without an index it
  // is a full-table scan over the heaviest (LLM-text) rows in the DB.
  @@index([tutorPromptDocId])
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

model BackgroundJob {
  id          String    @id @default(cuid())
  type        String    // "quiz_generation" or "grading"
  status      String    @default("pending") // pending, processing, done, error
  subjectMain String
  subjectSub  String    @default("Module")
  itemId      String?   // for grading jobs, references SRSItem
  error       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt
  completedAt DateTime?

  @@index([status, createdAt])
}

model AppConfig {
  id              Int      @id @default(1)
  currentSemester Int      @default(1)
  modulePresets   String   @default("[]") // JSON string array
  language        String   @default("german") // german or english
  wrapperMode     String   @default("all") // DEPRECATED (superseded by wrapperModules); kept for migration safety
  // Per-module wrapper on/off: JSON map { "<module name>": true }. A module NOT
  // listed (or false) uses the native Gemini API. Replaces the old global 3-way
  // wrapperMode. The native File API upload still runs on any native/fallback
  // call, so fallback works regardless of these toggles.
  wrapperModules  String   @default("{}")
  fileTransport   String   @default("inline") // "inline" (base64 in request) or "file_api" (File API upload + fileData URI)
  // Default Gemini model for generation/grading, and per-step overrides:
  // stepModels is a JSON map { "<step key>": "<model id>" }; a step not listed
  // uses aiModel. (Single-user app — no VIP gate here.)
  aiModel         String   @default("gemini-3.5-flash")
  stepModels      String   @default("{}")
  updatedAt       DateTime @updatedAt
}

model ReviewLog {
  id          String   @id @default(cuid())
  subjectMain String
  subjectSub  String
  level       Int      // The level they were at when they reviewed
  passed      Boolean  // Did they pass or repeat?
  completedAt DateTime @default(now())
  // Feedback history: the full Remediation Brief of THIS review, so grading
  // no longer overwrites the past (SRSItem.lastFeedback only holds the latest).
  feedback    String?
  // The SRSItem this review belongs to (soft reference — logs survive item deletion).
  itemId      String?
  userId      String?
  User        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([completedAt])
}
